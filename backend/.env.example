# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=blueprint_sw
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_long
JWT_EXPIRES_IN=7d

# CORS (comma-separated origins for frontend)
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Server
PORT=3001

# Email (Nodemailer SMTP — all forms + notifications go through this)
# Gmail: smtp.gmail.com + App Password from https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FAMILY=4
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=The Blueprint <your-email@gmail.com>
SMTP_TLS_REJECT_UNAUTHORIZED=true

# Admin email — receives contact forms, public feedback, contract alerts
ADMIN_EMAIL=your-email@gmail.com
